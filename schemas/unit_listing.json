{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UnitListingRow",
  "type": "object",
  "additionalProperties": false,
  "required": ["unit_id", "building_id", "unit_number", "last_updated"],
  "properties": {
    "unit_id": {"type": "string"},
    "building_id": {"type": "string"},
    "unit_number": {"type": "string"},
    "listing_url": {"type": "string"},
    "bedrooms": {"type": "string"},
    "bathrooms": {"type": "string"},
    "sqft": {"type": "string"},
    "base_rent": {"type": "string"},
    "concession_value_total": {"type": "string"},
    "lease_term_months": {"type": "string"},
    "available_date": {"type": "string"},
    "application_fee": {"type": "string"},
    "admin_fee": {"type": "string"},
    "security_deposit": {"type": "string"},
    "parking_cost": {"type": "string"},
    "pet_rent": {"type": "string"},
    "estimated_utilities": {"type": "string"},
    "balcony": {"enum": ["yes", "no", "unknown", ""]},
    "in_unit_laundry": {"enum": ["yes", "no", "unknown", ""]},
    "dishwasher": {"enum": ["yes", "no", "unknown", ""]},
    "central_ac": {"enum": ["yes", "no", "unknown", ""]},
    "natural_light": {"enum": ["yes", "no", "unknown", ""]},
    "closet_storage": {"enum": ["yes", "no", "unknown", ""]},
    "exact_unit_shown": {"enum": ["yes", "no", "unknown", ""]},
    "exposure": {"type": "string"},
    "nearest_noise_source": {"type": "string"},
    "notes": {"type": "string"},
    "last_updated": {"type": "string"}
  }
}
